<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/21.0.2"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.timetracker.controller.MainController"
      spacing="24.0"
      styleClass="app-root">

    <!-- Left Panel: Categories -->
    <VBox spacing="12" prefWidth="200" maxWidth="220" minWidth="180" styleClass="card">
        <Label text="Categories" styleClass="section-title"/>
        <ListView fx:id="categoryListView" prefHeight="420"/>
        <HBox spacing="8">
            <Button fx:id="addCategoryButton" text="Add Category" onAction="#onAddCategory" />
            <Button text="Edit" onAction="#onEditCategory" />
        </HBox>
        <Button text="Delete Category" onAction="#onDeleteCategory"/>
        <Label text="Tip: right-click a category for more actions" wrapText="true" styleClass="muted-text small-text"/>
    </VBox>

    <!-- Center Panel: Timer + Today -->
    <VBox spacing="24" alignment="TOP_CENTER" HBox.hgrow="ALWAYS" styleClass="card">

        <!-- Timer Block -->
        <VBox spacing="12" alignment="CENTER">
            <Label fx:id="timerLabel" text="00:00:00" styleClass="timer-label"/>
            <Label fx:id="selectedCategoryLabel" text="Selected Category: -" styleClass="headline-label"/>
            <Label fx:id="remainingTimeLabel" text="Remaining Today: -" styleClass="muted-text"/>
            <Label fx:id="startTimeLabel" text="Start Time: -" styleClass="muted-text"/>
            <Label fx:id="statusLabel" text="Status: Idle" styleClass="muted-text"/>
            <HBox spacing="10" alignment="CENTER">
                <Button fx:id="startStopButton" text="Start" onAction="#onStartStop" prefWidth="110"/>
                <Button fx:id="resetButton" text="Reset" onAction="#onReset" disable="true" prefWidth="110"/>
                <ComboBox prefWidth="130">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Normal"/>
                            <String fx:value="Pomodoro"/>
                            <String fx:value="Locked Mode"/>
                        </FXCollections>
                    </items>
                </ComboBox>
            </HBox>
        </VBox>
    </VBox>

    <!-- Right Panel: Auto Usage Inspector -->
    <VBox spacing="12" prefWidth="360" minWidth="320" maxWidth="Infinity" styleClass="card">
        <TabPane prefWidth="340" styleClass="pill-tabs">
            <tabs>
                <Tab text="Today" closable="false">
                    <content>
                        <VBox spacing="10">
                            <Label text="Today’s Breakdown" styleClass="section-title"/>
                            <StackPane prefHeight="120">
                                <ListView fx:id="timelineListView" />
                            </StackPane>
                            <HBox spacing="10">
                                <Button text="Export Day (.ics)" onAction="#onExportTodayIcs"/>
                                <Button text="Export Day (.csv)" onAction="#onExportTodayCsv"/>
                            </HBox>
                            <Label text="Today’s Summary" styleClass="subsection-title"/>
                            <TableView fx:id="todaySummaryTable" prefHeight="140">
                                <columns>
                                    <TableColumn fx:id="todaySummaryCategoryColumn" text="Category" prefWidth="180"/>
                                    <TableColumn fx:id="todaySummaryDurationColumn" text="Minutes" prefWidth="100"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </content>
                </Tab>
                <Tab text="Auto Usage" closable="false">
                    <content>
                        <VBox spacing="10">
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Auto tracking" styleClass="section-title"/>
                                <DatePicker fx:id="autoDatePicker"/>
                                <ToggleButton fx:id="trackingPauseToggle" text="Disable Auto Tracking" onAction="#onToggleTracking"/>
                                <Button text="Refresh" onAction="#onRefreshAuto"/>
                                <Button fx:id="autoExportButton" text="Export (.csv)" onAction="#onExportAutoCsv"/>
                            </HBox>
                            <TableView fx:id="autoTotalsTable" minWidth="320" prefHeight="360">
                                <columns>
                                    <TableColumn fx:id="autoAppColumn" text="App/Site" prefWidth="140"/>
                                    <TableColumn fx:id="autoUrlColumn" text="Domain/Title" prefWidth="140"/>
                                    <TableColumn fx:id="autoDurationColumn" text="Duration" prefWidth="90"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </content>
                </Tab>
                <Tab text="History" closable="false">
                    <content>
                        <VBox spacing="10">
                            <Label text="History" styleClass="section-title"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <VBox spacing="5">
                                    <Label text="From" />
                                    <DatePicker fx:id="rangeStartDatePicker"/>
                                </VBox>
                                <VBox spacing="5">
                                    <Label text="To" />
                                    <DatePicker fx:id="rangeEndDatePicker"/>
                                </VBox>
                                <Button text="Refresh" onAction="#onRefreshRange"/>
                            </HBox>
                            <Label fx:id="rangeErrorLabel" textFill="#cc0000"/>
                            <ListView fx:id="historyListView" prefHeight="140"/>
                            <Label text="Category Summary" styleClass="subsection-title"/>
                            <TableView fx:id="summaryTable" prefHeight="120">
                                <columns>
                                    <TableColumn fx:id="summaryCategoryColumn" text="Category" prefWidth="180"/>
                                    <TableColumn fx:id="summaryDurationColumn" text="Minutes" prefWidth="100"/>
                                </columns>
                            </TableView>
                            <HBox spacing="10">
                                <Button fx:id="exportRangeIcsButton" text="Export Range (.ics)" onAction="#onExportRangeIcs"/>
                                <Button fx:id="exportRangeCsvButton" text="Export Range (.csv)" onAction="#onExportRangeCsv"/>
                            </HBox>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </VBox>
</HBox>
